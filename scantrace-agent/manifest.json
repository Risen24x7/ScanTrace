{
  "display_information": {
    "name": "ScanTrace",
    "description": "Dead Reckoning — scan intelligence for your network",
    "background_color": "#1a1a2e",
    "long_description": "ScanTrace correlates raw firewall and IDS events into actionable cases and posts them to Slack with enriched IP context."
  },
  "features": {
    "bot_user": {
      "display_name": "ScanTrace",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/scantrace",
        "description": "Query ScanTrace cases",
        "usage_hint": "[cases|report <case-id>|help]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public",
        "commands",
        "channels:read",
        "app_mentions:read",
        "im:history",
        "im:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
