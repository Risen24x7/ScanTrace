# Copy to .env and fill in values
# Source before running: source .env

# From api.slack.com/apps -> OAuth & Permissions -> Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token-here

# From api.slack.com/apps -> Basic Information -> App-Level Tokens (connections:write scope)
SLACK_APP_TOKEN=xapp-your-token-here

# Path to the ScanTrace SQLite database
SCAN_TRACE_DB=../ScanTrace/scantrace.db

# Slack channel ID where alerts post
ALERT_CHANNEL=C0XXXXXXXXX
