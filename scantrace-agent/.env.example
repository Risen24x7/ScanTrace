# ScanTrace Bot — required tokens
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Database path (relative to scantrace-agent/ directory)
SCANTRACE_DB=../scantrace.db

# Slack channel ID to post case alerts (NOT channel name)
# Find it: right-click channel in Slack > Copy link > last segment is the ID (C0XXXXXXX)
ALERT_CHANNEL=C0XXXXXXXXX

# MCP server listen address (default is fine for local dev)
MCP_ADDR=:8765
