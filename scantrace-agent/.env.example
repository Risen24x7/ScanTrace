# ScanTrace Bot — required tokens
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Database path (relative to scantrace-agent/ directory)
SCANTRACE_DB=../scantrace.db

# Slack channel ID for incoming case alerts (NOT channel name — use sec-alerts)
# Find it: right-click channel in Slack > Copy link > last segment is the ID (C0XXXXXXX)
ALERT_CHANNEL=C0XXXXXXXXX

# Slack channel ID where external threat work is done — @mention LLM responses
# are posted here so prompts and analysis stay out of the raw alert feed.
# Example: sec-intel-external
EXTERNAL_THREAT_CHANNEL=C0BCYSW3KNC

# MCP server listen address (default is fine for local dev)
MCP_ADDR=:8765
