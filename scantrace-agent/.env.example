# ScanTrace Agent — Environment Variables
# Copy to .env and fill in values. Run from scantrace-agent/ directory.

# Required
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
ALERT_CHANNEL=C0BBP1EP68P

# Optional — LLM (defaults to desktop llama.cpp if not set)
# LLM_BASE_URL=http://192.168.50.250:11434
LLM_MODEL=Qwen3-30B-A3B-UD-Q3_K_XL

# Optional — Separate channel for LLM Q&A responses (defaults to ALERT_CHANNEL)
EXTERNAL_THREAT_CHANNEL=C0BCYSW3KNC

# ── Database path ──────────────────────────────────────────────────────────────
# IMPORTANT: use an ABSOLUTE path. The default "../scantrace.db" is relative to
# the working directory at launch time. If you start the binary from any directory
# other than scantrace-agent/, adddevice writes to a different file than devices
# reads from, so the registry appears empty.
#
# Recommended: set this to the same file the syslog ingester uses.
DB_PATH=/opt/scantrace/scantrace.db
# ──────────────────────────────────────────────────────────────────────────────

# Optional — WAN IP of your router (auto-detected from syslog if blank)
# WAN_IP=

# Optional — RTS base URL
# RTS_BASE_URL=

# Syslog listener port (default 5140)
# SCANTRACE_SYSLOG_PORT=5140
