# Slack bot token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Slack channel ID for raw inbound scan alerts
ALERT_CHANNEL=

# Slack channel ID where external threat work is done (LLM prompts/responses)
EXTERNAL_THREAT_CHANNEL=C0BCYSW3KNC

# Your public WAN IP — used to correctly classify wan_new_connection dst as
# the gateway edge interface rather than an unknown internal host.
WAN_IP=

# RTS base URL (leave blank to disable)
RTS_BASE_URL=

# LLM inference endpoint (OpenAI-compatible, e.g. http://localhost:8080)
LLM_BASE_URL=

# LLM model name (optional — omit to use server default)
LLM_MODEL=
