# ScanTrace Agent — Environment Variables
# Copy to .env and fill in values. Run from scantrace-agent/ directory.

# Required
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
ALERT_CHANNEL=C0BBP1EP68P

# Optional — LLM (defaults to localhost if not set)
LLM_BASE_URL=http://127.0.0.1:11434
# Do not include a /v1 suffix; the agent adds it automatically
# LLM_MODEL=            # leave blank to disable LLM until configured (MCP-only mode)

# Optional — Separate channel for LLM Q&A responses (defaults to ALERT_CHANNEL)
EXTERNAL_THREAT_CHANNEL=C0BCYSW3KNC

# ── Database path ──────────────────────────────────────────────────────────────
# IMPORTANT: set an ABSOLUTE path. Relative paths resolve from the working
# directory at launch time and can split state between files.
# Recommended: keep the DB under /var/lib/scantrace.
DB_PATH=/var/lib/scantrace/scantrace.db
# ──────────────────────────────────────────────────────────────────────────────

# Optional — WAN IP of your router (auto-detected from syslog if blank)
# WAN_IP=

# Optional — RTS base URL
# RTS_BASE_URL=

# Syslog listener port (default 5140)
# SCANTRACE_SYSLOG_PORT=5140
